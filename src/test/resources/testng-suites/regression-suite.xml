<!DOCTYPE suite SYSTEM "https://testng.org/testng-1.0.dtd">
<suite name="RestfulBooker Regression Suite" verbose="1">

    <test name="Regression Tests">
        <groups>
            <run>
                <include name="regression"/>
            </run>
        </groups>

        <classes>
            <class name="com.restfulbooker.tests.AuthTests"/>
            <class name="com.restfulbooker.tests.HealthCheckTest"/>
            <class name="com.restfulbooker.tests.GetAllBookingTest"/>
            <class name="com.restfulbooker.tests.CreateBookingTest"/>
            <class name="com.restfulbooker.tests.GetBookingTest"/>
            <class name="com.restfulbooker.tests.UpdateBookingTest"/>
            <class name="com.restfulbooker.tests.PartialUpdateBookingTest"/>
            <class name="com.restfulbooker.tests.DeleteBookingTest"/>
            <class name="com.restfulbooker.tests.FilterBookingTest"/>
        </classes>
    </test>

</suite>